{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "/Users/gandazgul/Documents/web/mnemosyne/opencode-mnemosyne",
    // "opencode-mnemosyne",
    // notifier has some errors, Desktop app notifies anyways
    // "@mohak34/opencode-notifier"
    "@plannotator/opencode@latest"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    }
  },
  "experimental": {
    "bash": {
      "timeout_ms": 600000
    }
  },
  "permission": {
    "bash": {
      "git commit*": "deny",
      "git push*": "deny"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": {
          "*": "deny",
          "*.md": "allow"
        }
      }
    }
  }
}
